/* app.wxss — 全局样式 */
page {
  background-color: #F5F7FA;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: #1F2937;
  box-sizing: border-box;
}

/* 通用按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #4F46E5, #7C3AED);
  color: #fff;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  width: 100%;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-secondary {
  background: #fff;
  color: #4F46E5;
  border: 2rpx solid #4F46E5;
  border-radius: 50rpx;
  font-size: 30rpx;
  padding: 20rpx 40rpx;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: #9CA3AF;
  font-size: 28rpx;
}
