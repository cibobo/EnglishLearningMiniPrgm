<!-- pages/lessons/lessons.wxml -->
<view class="page">
  <!-- 顶部沉浸式 Header -->
  <view class="header">
    <view class="header-left">
      <view class="icon-bubble">
        <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" class="header-avatar" mode="aspectFill" bindtap="onChangeAvatar" />
        <text wx:else class="emoji-icon" bindtap="onChangeAvatar">👋</text>
      </view>
      <text class="greeting">Hi, {{userInfo.name}}</text>
      <view class="checkin-trigger" bindtap="onShowCheckin" hover-class="checkin-trigger-hover">
        <text>🏅 打卡</text>
      </view>
    </view>
    <view class="logout-btn" bindtap="onLogout" hover-class="logout-hover">
      <text>退出</text>
    </view>
  </view>

  <!-- 欢迎介绍栏 -->
  <view class="intro-section">
    <text class="intro-title">Where should we go?</text>
    <text class="intro-desc">Pick an adventure to start learning!</text>
  </view>

  <!-- 加载中骨架 -->
  <view wx:if="{{loading}}" class="skeleton-list">
    <view wx:for="{{[1,2,3]}}" wx:key="index" class="skeleton-card"></view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{lessons.length === 0}}" class="empty-state">
    <text class="empty-icon">📭</text>
    <text class="empty-text">老师暂未发布课程</text>
    <text class="empty-hint">请等待老师上传跟读材料</text>
  </view>

  <!-- 课程列表 (Bouncy Cards) -->
  <scroll-view wx:else scroll-y class="lesson-list" enhanced show-scrollbar="{{false}}"
    scroll-into-view="{{scrollIntoCardId}}"
    scroll-with-animation="{{true}}"
  >
    <view
      wx:for="{{lessons}}"
      wx:key="id"
      id="lesson-card-{{item.id}}"
      class="bouncy-card {{item.colorTheme}} {{item.id === stampingLessonId ? 'card-stamp-shake' : ''}}"
      bindtap="onLessonTap"
      data-id="{{item.id}}"
      data-theme="{{item.colorTheme}}"
      hover-class="card-hover"
    >
      <view class="card-deco">
        <image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" class="deco-bg-img" lazy-load />
      </view>


      <!-- 完成标记 -->
      <view wx:if="{{item.isLocked}}" class="completed-badge">
        <text>COMPLETED</text>
      </view>

      <!-- 居中的奖杯图片 -->
      <view wx:if="{{item.trophyLevel}}" class="trophy-center {{item.id === stampedLessonId ? 'trophy-stamped' : ''}}">
        <image class="trophy-img" src="/images/{{item.trophyLevel}}.png" mode="aspectFit" />
      </view>

      <view class="card-content">
        <view class="card-header">
           <text class="status-badge">Lesson {{index + 1}}</text>
           <image wx:if="{{item.requiresTeacherReview}}" src="/images/teacher_avatar.png" class="teacher-review-inline" mode="aspectFit" />
        </view>
        <text class="card-title">{{item.title}}</text>
        <text class="card-desc">📝 {{item.totalSentences}} sentences</text>
      </view>

      <view class="card-bottom">
        <view class="progress-section">
          <view class="progress-text-row">
            <text class="progress-label">PROGRESS</text>
            <text class="progress-value">{{item.completedSentences}} / {{item.totalSentences}}</text>
          </view>
          <!-- 胶囊进度条 -->
          <view class="progress-track">
            <view class="progress-fill" style="width: {{item.progressPercent}}%"></view>
          </view>
        </view>
        <view class="btn-play" wx:if="{{!item.isLocked}}">
          <text>GO!</text>
        </view>
        <view class="hundred-percent" wx:else>
          <text>100%</text>
        </view>
      </view>
    </view>
    <view style="height: 100rpx;"></view> <!-- Bottom spacing -->
  </scroll-view>

  <!-- 打卡奖励弹窗组件 -->
  <checkin 
    show="{{showCheckinModal}}" 
    streak="{{streak}}" 
    totalSentences="{{totalSentences}}" 
    avatarUrl="{{userInfo.avatarUrl}}" 
    bind:close="onCloseCheckin" 
    bind:start="onCloseCheckin"
  />

  <!-- Avatar Picker Overlay -->
  <view class="overlay" wx:if="{{showAvatarPicker}}">
    <view class="avatar-card">
      <view class="card-close" bindtap="onCloseAvatarPicker">✕</view>
      <text class="avatar-title">更换头像</text>
      
      <view class="avatar-grid">
        <view
          wx:for="{{avatars}}"
          wx:key="*this"
          class="avatar-item {{selectedAvatar === item ? 'avatar-item--selected' : ''}}"
          data-url="{{item}}"
          bindtap="onSelectAvatar"
        >
          <image src="{{item}}" mode="aspectFill" class="avatar-img" />
        </view>
      </view>
      
      <button
        class="btn-go bouncy"
        disabled="{{!selectedAvatar}}"
        bindtap="onConfirmAvatar"
      >
        <text class="btn-go__text">保存</text>
      </button>
    </view>
  </view>

</view>

<!-- ===== 奖杯印章飞入 Overlay（跨页动画第二阶段） ===== -->
<view 
  wx:if="{{showTrophyStamp}}" 
  class="stamp-overlay"
  catchtap="preventBubble"
>
  <image 
    class="stamp-trophy-img {{stampAnimClass}}"
    src="/images/{{stampTrophyLevel}}.png" 
    mode="aspectFit"
    style="transform: translate({{stampTargetX}}px, {{stampTargetY}}px) scale({{stampScale}}) rotate({{stampRotate}}deg);"
  />
</view>

