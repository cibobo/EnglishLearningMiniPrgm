.page {
  height: 100vh;
  overflow: hidden;
  background: #eefdf2;
  display: flex;
  flex-direction: column;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  box-sizing: border-box;
}

/* =============================================
   Header 沉浸式风格
   ============================================= */
.header {
  padding: 100rpx 40rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #eefdf2;
}

.header-left { 
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.icon-bubble {
  background: #c2e8ff;
  border-radius: 999rpx;
  padding: 12rpx 16rpx;
  font-size: 32rpx;
}

.greeting {
  font-size: 40rpx;
  font-weight: 800;
  color: #7e5700;
}

.logout-btn {
  padding: 12rpx 32rpx;
  background: rgba(255, 255, 255, 0.6);
  border: 4rpx solid #fff;
  border-radius: 999rpx;
  color: #004d67;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.logout-hover {
  transform: scale(0.95);
  transition: transform 0.2s;
}

/* =============================================
   Intro
   ============================================= */
.intro-section {
  padding: 0 40rpx 60rpx;
  text-align: center;
}

.intro-title {
  display: block;
  font-size: 60rpx;
  font-weight: 800;
  color: #7e5700;
  margin-bottom: 12rpx;
}

.intro-desc {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #006688;
}

/* =============================================
   Empty State / Loading
   ============================================= */
.skeleton-list { padding: 40rpx; }
.skeleton-card {
  height: 300rpx;
  background: rgba(255,255,255,0.4);
  border-radius: 48rpx;
  margin-bottom: 32rpx;
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 34rpx; font-weight: 700; color: #474747; }
.empty-hint { font-size: 26rpx; color: #777; margin-top: 12rpx; }

/* =============================================
   Lesson List & Bouncy Cards
   ============================================= */
.lesson-list {
  flex: 1;
  height: 0;
  padding: 0;
  box-sizing: border-box;
  width: 100%;
}

.bouncy-card {
  position: relative;
  background: #ffffff;
  border: 8rpx solid #ffffff;
  border-radius: 48rpx;
  padding: 40rpx;
  margin: 0 40rpx 40rpx;
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
  transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.card-hover {
  transform: scale(0.95) rotate(-1deg);
}

/* Base Decoration Images */
.card-deco {
  position: absolute;
  top: 0;
  right: 0;
  width: 100%;
  height: 100%;
  opacity: 0.15;
  pointer-events: none;
}
.deco-bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Card Content Structure */
.card-content {
  position: relative;
  z-index: 10;
  flex: 1;
}

.card-header {
  margin-bottom: 24rpx;
}

.status-badge {
  background: rgba(255,255,255,0.5);
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
  text-transform: uppercase;
  color: inherit; /* will be overridden by theme */
}

.card-title {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: 16rpx;
}

.card-desc {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  opacity: 0.8;
}

/* Card Bottom actions */
.card-bottom {
  position: relative;
  z-index: 10;
  margin-top: 60rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.progress-section {
  flex: 1;
  margin-right: 32rpx;
}

.progress-text-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 12rpx;
}

.progress-label {
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  opacity: 0.7;
}

.progress-value {
  font-size: 40rpx;
  font-weight: 800;
}

.progress-track {
  width: 100%;
  height: 24rpx;
  background: rgba(0,0,0,0.1);
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #ffffff;
  border-radius: 999rpx;
  transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-play {
  padding: 24rpx 40rpx;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #fff;
  background: #000; /* overridden by theme */
  box-shadow: 0 8rpx 0 0 rgba(0,0,0,0.2);
}

/* =============================================
   Themes (The Candy Palette) & Trophy
   ============================================= */

.trophy-badge {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  z-index: 20;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.18);
  animation: trophy-pop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.trophy-emoji { font-size: 52rpx; }
.trophy-gold   { background: linear-gradient(135deg, #fff7e0, #ffd700); }
.trophy-silver { background: linear-gradient(135deg, #f0f0f0, #c0c0c0); }
.trophy-bronze { background: linear-gradient(135deg, #fde8d8, #cd7f32); }

@keyframes trophy-pop {
  0%   { transform: scale(0); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

/* Theme Primary (Orange/Yellow) */
.theme-primary {
  background: #ffdeac;
  border-color: #ffffff;
}
.theme-primary .status-badge { color: #7e5700; background: #ffeac7; border: 2rpx solid rgba(126,87,0,0.1); }
.theme-primary .card-title { color: #604100; }
.theme-primary .card-desc { color: #604100; }
.theme-primary .progress-label { color: #604100; }
.theme-primary .progress-value { color: #604100; }
.theme-primary .progress-fill { background: #ffba38; }
.theme-primary .btn-play { 
  background: #7e5700;
  box-shadow: 0 8rpx 0 0 #604100;
}

/* Theme Secondary (Sky Blue) */
.theme-secondary {
  background: #c2e8ff;
  border-color: #ffffff;
}
.theme-secondary .status-badge { color: #004d67; background: #dbf1ff; border: 2rpx solid rgba(0,77,103,0.1); }
.theme-secondary .card-title { color: #004d67; }
.theme-secondary .card-desc { color: #004d67; }
.theme-secondary .progress-label { color: #004d67; }
.theme-secondary .progress-value { color: #004d67; }
.theme-secondary .progress-fill { background: #75d1ff; }
.theme-secondary .btn-play { 
  background: #006688;
  box-shadow: 0 8rpx 0 0 #004d67;
}

/* Theme Tertiary (Soft Pink) */
.theme-tertiary {
  background: #ffd9df;
  border-color: #ffffff;
}
.theme-tertiary .status-badge { color: #81233f; background: #ffe8eb; border: 2rpx solid rgba(129,35,63,0.1); }
.theme-tertiary .card-title { color: #81233f; }
.theme-tertiary .card-desc { color: #81233f; }
.theme-tertiary .progress-label { color: #81233f; }
.theme-tertiary .progress-value { color: #81233f; }
.theme-tertiary .progress-fill { background: #ffb1c0; }
.theme-tertiary .btn-play { 
  background: #a03b56;
  box-shadow: 0 8rpx 0 0 #81233f;
}
