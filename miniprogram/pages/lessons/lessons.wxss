.page {
  height: 100vh;
  overflow: hidden;
  background: #eefdf2;
  display: flex;
  flex-direction: column;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  box-sizing: border-box;
}

/* =============================================
   Header 沉浸式风格
   ============================================= */
.header {
  padding: 100rpx 40rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #eefdf2;
}

.header-left { 
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.icon-bubble {
  background: #c2e8ff;
  border-radius: 999rpx;
  padding: 6rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
  display: block;
}

/* Avatar Frames (CSS Only) */
.avatar-frame-bronze {
  box-shadow: 0 0 0 4rpx #cd7f32;
  background: linear-gradient(135deg, #cd7f32, #a0522d);
}

.avatar-frame-silver {
  box-shadow: 0 0 0 4rpx #c0c0c0;
  background: linear-gradient(135deg, #e0e0e0, #9e9e9e);
}

.avatar-frame-gold {
  box-shadow: 0 0 0 4rpx #ffd700, 0 0 12rpx rgba(255,215,0,0.6);
  background: linear-gradient(135deg, #fff3b0, #ffba38);
}

.avatar-frame-diamond {
  box-shadow: 0 0 0 4rpx #00ffff, 0 0 16rpx rgba(0,255,255,0.8);
  background: linear-gradient(135deg, #b9f2ff, #00d4ff);
  animation: pulse-glow 2s infinite;
}

@keyframes pulse-glow {
  0% { box-shadow: 0 0 0 4rpx #00ffff, 0 0 8rpx rgba(0,255,255,0.5); }
  50% { box-shadow: 0 0 0 4rpx #00ffff, 0 0 20rpx rgba(0,255,255,1); }
  100% { box-shadow: 0 0 0 4rpx #00ffff, 0 0 8rpx rgba(0,255,255,0.5); }
}

.user-info-col {
  display: flex;
  flex-direction: column;
}

.greeting {
  font-size: 40rpx;
  font-weight: 800;
  color: #7e5700;
}

.achievements-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 4rpx;
}

.level-badge {
  font-size: 20rpx;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(90deg, #ff9a9e 0%, #fecfef 99%, #fecfef 100%);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
  box-shadow: 0 4rpx 8rpx rgba(255,154,158,0.3);
}

.trophy-counts {
  display: flex;
  gap: 8rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #7e5700;
  background: rgba(255, 255, 255, 0.6);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.checkin-trigger {
  padding: 10rpx 24rpx;
  background: #ffba38;
  border-radius: 999rpx;
  color: #604100;
  font-size: 26rpx;
  font-weight: 800;
  box-shadow: 0 4rpx 0 #7e5700;
  margin-left: 10rpx;
}

.checkin-trigger-hover {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 0 #7e5700;
}

.logout-btn {
  padding: 12rpx 32rpx;
  background: rgba(255, 255, 255, 0.6);
  border: 4rpx solid #fff;
  border-radius: 999rpx;
  color: #004d67;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.logout-hover {
  transform: scale(0.95);
  transition: transform 0.2s;
}

/* =============================================
   Intro
   ============================================= */
.intro-section {
  padding: 0 40rpx 60rpx;
  text-align: center;
}

.intro-title {
  display: block;
  font-size: 60rpx;
  font-weight: 800;
  color: #7e5700;
  margin-bottom: 12rpx;
}

.intro-desc {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #006688;
}

/* =============================================
   Empty State / Loading
   ============================================= */
.skeleton-list { padding: 40rpx; }
.skeleton-card {
  height: 300rpx;
  background: rgba(255,255,255,0.4);
  border-radius: 48rpx;
  margin-bottom: 32rpx;
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 34rpx; font-weight: 700; color: #474747; }
.empty-hint { font-size: 26rpx; color: #777; margin-top: 12rpx; }

/* =============================================
   Lesson List & Bouncy Cards
   ============================================= */
.lesson-list {
  flex: 1;
  height: 0;
  padding: 0;
  box-sizing: border-box;
  width: 100%;
}

.bouncy-card {
  position: relative;
  background: #ffffff;
  border: 8rpx solid #ffffff;
  border-radius: 48rpx;
  padding: 40rpx;
  margin: 0 40rpx 40rpx;
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
  transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.card-hover {
  transform: scale(0.95) rotate(-1deg);
}

/* Base Decoration Images */
.card-deco {
  position: absolute;
  top: 0;
  right: 0;
  width: 100%;
  height: 100%;
  opacity: 0.15;
  pointer-events: none;
}
.deco-bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Card Content Structure */
.card-content {
  position: relative;
  z-index: 10;
  flex: 1;
}

.card-header {
  margin-bottom: 24rpx;
}

.status-badge {
  background: rgba(255,255,255,0.5);
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
  text-transform: uppercase;
  color: inherit; /* will be overridden by theme */
}

.card-title {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: 16rpx;
}

.card-desc {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  opacity: 0.8;
}

/* Card Bottom actions */
.card-bottom {
  position: relative;
  z-index: 10;
  margin-top: 60rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.progress-section {
  flex: 1;
  margin-right: 32rpx;
}

.progress-text-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 12rpx;
}

.progress-label {
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  opacity: 0.7;
}

.progress-value {
  font-size: 40rpx;
  font-weight: 800;
}

.progress-track {
  width: 100%;
  height: 24rpx;
  background: rgba(0,0,0,0.1);
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #ffffff;
  border-radius: 999rpx;
  transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-play {
  padding: 24rpx 40rpx;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #fff;
  background: #000; /* overridden by theme */
  box-shadow: 0 8rpx 0 0 rgba(0,0,0,0.2);
}

/* =============================================
   Themes (The Candy Palette) & Trophy
   ============================================= */

.completed-badge {
  position: absolute;
  top: 40rpx;
  right: 40rpx;
  z-index: 20;
  font-size: 38rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  animation: pop-in 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

/* 需要老师验收：inline avatar 跟在 Lesson N 标签旁 */
.teacher-review-inline {
  width: 50rpx;
  height: 50rpx;
  margin-left: 10rpx;
  vertical-align: middle;
  border-radius: 50%;
}

.trophy-center {
  position: absolute;
  top: 52%;
  left: 55%;
  transform: translate(-50%, -50%);
  z-index: 15;
  width: 250rpx;
  height: 250rpx;
  animation: trophy-bounce 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}
.trophy-img {
  width: 100%;
  height: 100%;
}

.hundred-percent {
  font-size: 64rpx;
  font-weight: 900;
  padding-right: 16rpx;
  letter-spacing: -2rpx;
  line-height: 1.2;
  transform: translateY(6rpx);
  animation: pop-in 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes trophy-bounce {
  0%   { transform: translate(-50%, -20%) scale(0.5) rotate(-15deg); opacity: 0; }
  100% { transform: translate(-50%, -50%) scale(1) rotate(15deg); opacity: 1; }
}

/* 印章落地后的卡片奖杯：跳过 bounce，直接以最终角度静止出现，与 overlay 无缝衔接 */
.trophy-center.trophy-stamped {
  animation: none;
  transform: translate(-50%, -50%) scale(1) rotate(15deg);
  opacity: 1;
}

@keyframes pop-in {
  0%   { transform: scale(0); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

/* Theme Primary (Orange/Yellow) */
.theme-primary {
  background: #ffdeac;
  border-color: #ffffff;
}
.theme-primary .completed-badge { color: #7e5700; text-shadow: 0 4rpx 16rpx rgba(126,87,0,0.1); }
.theme-primary .hundred-percent { color: #f29f05; text-shadow: 0 4rpx 0 rgba(255,255,255,0.4); }
.theme-primary .status-badge { color: #7e5700; background: #ffeac7; border: 2rpx solid rgba(126,87,0,0.1); }
.theme-primary .card-title { color: #604100; }
.theme-primary .card-desc { color: #604100; }
.theme-primary .progress-label { color: #604100; }
.theme-primary .progress-value { color: #604100; }
.theme-primary .progress-fill { background: #ffba38; }
.theme-primary .btn-play { 
  background: #7e5700;
  box-shadow: 0 8rpx 0 0 #604100;
}

/* Theme Secondary (Sky Blue) */
.theme-secondary {
  background: #c2e8ff;
  border-color: #ffffff;
}
.theme-secondary .completed-badge { color: #006688; text-shadow: 0 4rpx 16rpx rgba(0,102,136,0.1); }
.theme-secondary .hundred-percent { color: #1fb1f5; text-shadow: 0 4rpx 0 rgba(255,255,255,0.4); }
.theme-secondary .status-badge { color: #004d67; background: #dbf1ff; border: 2rpx solid rgba(0,77,103,0.1); }
.theme-secondary .card-title { color: #004d67; }
.theme-secondary .card-desc { color: #004d67; }
.theme-secondary .progress-label { color: #004d67; }
.theme-secondary .progress-value { color: #004d67; }
.theme-secondary .progress-fill { background: #75d1ff; }
.theme-secondary .btn-play { 
  background: #006688;
  box-shadow: 0 8rpx 0 0 #004d67;
}

/* Theme Tertiary (Soft Pink) */
.theme-tertiary {
  background: #ffd9df;
  border-color: #ffffff;
}
.theme-tertiary .completed-badge { color: #a03b56; text-shadow: 0 4rpx 16rpx rgba(160,59,86,0.1); }
.theme-tertiary .hundred-percent { color: #ff6b8b; text-shadow: 0 4rpx 0 rgba(255,255,255,0.4); }
.theme-tertiary .status-badge { color: #81233f; background: #ffe8eb; border: 2rpx solid rgba(129,35,63,0.1); }
.theme-tertiary .card-title { color: #81233f; }
.theme-tertiary .card-desc { color: #81233f; }
.theme-tertiary .progress-label { color: #81233f; }
.theme-tertiary .progress-value { color: #81233f; }
.theme-tertiary .progress-fill { background: #ffb1c0; }
.theme-tertiary .btn-play { 
  background: #a03b56;
  box-shadow: 0 8rpx 0 0 #81233f;
}

/* =============================================
   Profile Overlay
   ============================================= */
.profile-card {
  background: #ffffff;
  width: 620rpx;
  border-radius: 48rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 16rpx 60rpx rgba(0, 0, 0, 0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.profile-avatar-wrapper {
  position: relative;
  border-radius: 50%;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx;
}

.profile-avatar-wrapper.avatar-frame-bronze {
  box-shadow: 0 0 0 8rpx #cd7f32;
}
.profile-avatar-wrapper.avatar-frame-silver {
  box-shadow: 0 0 0 8rpx #c0c0c0;
}
.profile-avatar-wrapper.avatar-frame-gold {
  box-shadow: 0 0 0 8rpx #ffd700, 0 0 24rpx rgba(255,215,0,0.6);
}
.profile-avatar-wrapper.avatar-frame-diamond {
  box-shadow: 0 0 0 8rpx #00ffff, 0 0 32rpx rgba(0,255,255,0.8);
  animation: profile-pulse-glow 2s infinite;
}

@keyframes profile-pulse-glow {
  0% { box-shadow: 0 0 0 8rpx #00ffff, 0 0 16rpx rgba(0,255,255,0.5); }
  50% { box-shadow: 0 0 0 8rpx #00ffff, 0 0 40rpx rgba(0,255,255,1); }
  100% { box-shadow: 0 0 0 8rpx #00ffff, 0 0 16rpx rgba(0,255,255,0.5); }
}

.profile-big-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  display: block;
}

.profile-emoji-avatar {
  font-size: 80rpx;
}

.edit-icon {
  position: absolute;
  bottom: 0;
  right: 0;
  background: #ffba38;
  color: #604100;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.1);
  z-index: 10;
}

.profile-header-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 16rpx;
}

.profile-name {
  font-size: 48rpx;
  font-weight: 800;
  color: #474747;
  line-height: 1.2;
}

.profile-classes {
  font-size: 24rpx;
  font-weight: 600;
  color: #888;
  margin-top: 8rpx;
  text-align: center;
}

.profile-level-badge {
  margin-bottom: 40rpx;
}

.profile-level-badge text {
  font-size: 24rpx;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(90deg, #ff9a9e 0%, #fecfef 99%, #fecfef 100%);
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
  box-shadow: 0 8rpx 16rpx rgba(255,154,158,0.3);
}

.stats-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

.stat-row {
  border-radius: 32rpx;
  padding: 16rpx 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.02);
}

.stat-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
}

.streak-box {
  background-color: #e8f7ec;
  border: 4rpx solid #d7e6dc;
  transform: rotate(0deg);
}

.lessons-box {
  background-color: #e6f4ff;
  border: 4rpx solid #cce5ff;
  transform: rotate(0deg);
}

.sentences-box {
  background-color: #ffd9df;
  border: 4rpx solid #ffb1c0;
  transform: rotate(0deg);
}

.icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 4rpx 8rpx rgba(255,255,255,0.6), 0 4rpx 8rpx rgba(0,0,0,0.05);
}
.icon { font-size: 32rpx; }

.primary-box { background-color: #ffdeac; }
.secondary-box { background-color: #c2e8ff; }
.tertiary-box { background-color: #ffb1c0; }
.gold-box { background-color: #ffdeac; }

.stat-val {
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-lbl {
  font-size: 26rpx;
  font-weight: 800;
}

.streak-box .stat-val { color: #2c7a4b; }
.streak-box .stat-lbl { color: #4b9e6c; }

.lessons-box .stat-val { color: #004d67; }
.lessons-box .stat-lbl { color: #006688; }

.sentences-box .stat-val { color: #a03b56; }
.sentences-box .stat-lbl { color: #cc5473; }


.trophy-row-val {
  display: flex;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #7e5700;
}

.trophy-stat-box {
  background-color: #fff8eb;
  border: 4rpx solid #ffeac7;
}

.trophy-stat-box .stat-lbl {
  color: #7e5700;
}

/* =============================================
   Avatar Picker Overlay
   ============================================= */
.overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(8rpx);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-card {
  background: #ffffff;
  width: 620rpx;
  border-radius: 40rpx;
  padding: 48rpx;
  box-shadow: 0 16rpx 60rpx rgba(18, 30, 24, 0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  position: relative;
}

.card-close {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  font-size: 40rpx;
  color: #a09888;
  font-weight: 800;
  padding: 10rpx;
  line-height: 1;
}

.avatar-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #474747;
}

.avatar-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  width: 100%;
  justify-items: center;
}

.avatar-item {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid #e8f7ec;
  padding: 8rpx;
  box-sizing: border-box;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-item--selected {
  border-color: #ffba38;
  background: #fff8eb;
  transform: scale(1.05);
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.btn-go {
  width: 100%;
  background: linear-gradient(180deg, #ffcc55 0%, #ffba38 100%);
  border-radius: 999rpx;
  padding: 24rpx 0;
  box-shadow: 0 7rpx 0 0 #604100, 0 14rpx 28rpx rgba(126, 87, 0, 0.22);
  border: 4rpx solid #604100;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.btn-go[disabled] {
  background: linear-gradient(180deg, #e0d9cc 0%, #c8c2b5 100%);
  box-shadow: 0 7rpx 0 0 #a09888, 0 14rpx 28rpx rgba(0, 0, 0, 0.1);
  border-color: #a09888;
}

.btn-go__text {
  font-size: 36rpx;
  font-weight: 900;
  color: #604100;
  letter-spacing: 4rpx;
}

/* =============================================
   奖杯印章飞入 Overlay（跨页庆典动画第二阶段）
   ============================================= */

/* 全屏容器：从屏幕中央开始，无背景 */
.stamp-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 8000;
  pointer-events: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 飞行中的奖杯图片 */
.stamp-trophy-img {
  position: absolute;
  width: 320rpx;
  height: 320rpx;
  /* 默认无 transition，立即定位到起始点 */
  transition: none;
  filter: drop-shadow(0 16rpx 48rpx rgba(0, 0, 0, 0.3));
  transform-origin: center center;
  opacity: 1;
}

/* 阶段1：立即出现在中心，无动画 */
.stamp-trophy-img.stamp-phase-start {
  transition: none;
}

/* 阶段2：加速飞向目标卡片，同时旋转到 15deg */
.stamp-trophy-img.stamp-phase-flying {
  transition: transform 0.6s cubic-bezier(0.55, 0, 1, 0.45);
}

/* 阶段3：印章弹性效果，旋转过冲到 22deg 再回弹到 15deg */
.stamp-trophy-img.stamp-phase-stamp {
  transition: transform 0.22s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  filter: drop-shadow(0 8rpx 24rpx rgba(0, 0, 0, 0.2));
}


/* 卡片接收印章时的震动效果 */
@keyframes card-stamp-shake {
  0%   { transform: scale(1) rotate(0deg); }
  20%  { transform: scale(1.06) rotate(-2deg); }
  40%  { transform: scale(0.97) rotate(1deg); }
  60%  { transform: scale(1.03) rotate(-1deg); }
  80%  { transform: scale(0.99) rotate(0.5deg); }
  100% { transform: scale(1) rotate(0deg); }
}

.card-stamp-shake {
  animation: card-stamp-shake 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
}


