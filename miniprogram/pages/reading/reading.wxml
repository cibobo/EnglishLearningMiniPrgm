<!-- pages/reading/reading.wxml -->
<view class="page">
  <!-- 全屏虚化背景 (随滚动切换分组插画) -->
  <image class="global-bg" src="{{groups[activeGroupIndex].imageUrl || lesson.imageUrl}}" mode="aspectFill" />
  <view class="global-bg-overlay"></view>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="skeleton-card"></view>
    <view class="skeleton-card"></view>
  </view>

  <block wx:else>
    <!-- 顶部状态小卡片 (Header) -->
    <view class="top-header-glass {{colorTheme}}">
      <!-- 课程封面作为虚化背景 -->
      <image wx:if="{{lesson.imageUrl}}" class="header-bg-img" src="{{lesson.imageUrl}}" mode="aspectFill"/>
      <view class="header-bg-overlay"></view>

      <!-- 完美对齐微信胶囊的绝对定位返回按键 -->
      <view 
        class="nav-back-pill" 
        style="top: {{navTop}}px; height: {{navHeight}}px; width: {{navHeight * 1.5}}px;" 
        hover-class="nav-back-pill-hover" 
        bindtap="onNavigateBack"
      >
        <view class="nav-pill-icon"></view>
      </view>

      <view class="header-content">
         <view class="header-left">
           <image wx:if="{{lesson.imageUrl}}" class="header-thumb" src="{{lesson.imageUrl}}" mode="aspectFill"/>
           <text class="header-title">{{lesson.title}}</text>
         </view>
         <view class="header-progress">
           <text class="progress-text">{{recordedCount}} / {{sentences.length}}</text>
           <text class="star-icon">⭐</text>
         </view>
      </view>
      <!-- 进度条胶囊 -->
      <view class="header-progress-track">
         <view class="header-progress-fill" style="width: {{sentences.length ? (recordedCount / sentences.length * 100) : 0}}%;"></view>
      </view>
    </view>

    <!-- 主滚动区域 -->
    <scroll-view class="content-scroll" scroll-y enable-passive bindscroll="onContentScroll">
      <!-- 分组内容区 -->
      <view class="groups-container">
        <view 
          wx:for="{{groups}}" 
          wx:for-item="group" 
          wx:for-index="gIndex" 
          wx:key="id" 
          class="image-group"
          id="group-{{gIndex}}"
        >
          <!-- 隐形锡点：用于检测滚动到哪个分组 -->
          <view class="group-anchor" id="group-anchor-{{gIndex}}"></view>
          
          <!-- 句子序列 -->
          <view class="sentences-list">
            <view
              wx:for="{{group.sentences}}"
              wx:for-item="sentence"
              wx:for-index="sIdx"
              wx:key="id"
              id="sentence-{{group.indices[sIdx]}}"
              class="bouncy-sentence-card {{group.indices[sIdx] === currentIndex ? ('card-active' + ((playingIndex === currentIndex || isRecording) ? ' card-playing' : '')) : (recordings[group.indices[sIdx]] ? 'card-completed' : 'card-locked')}}"
              bindtap="onSentenceTap"
              data-index="{{group.indices[sIdx]}}"
            >
              
              <!-- 已完成状态或未开始状态 UI -->
              <view class="sentence-content" wx:if="{{group.indices[sIdx] !== currentIndex}}">
                 <view class="sentence-text-row">
                    <text class="status-icon" wx:if="{{recordings[group.indices[sIdx]]}}">✅</text>
                    <text class="status-icon" wx:else>🔒</text>
                    <text class="s-text">{{sentence.text}}</text>
                 </view>
              </view>

              <!-- 当前激活状态 UI -->
              <view class="active-content-layout" wx:else>
                 <view class="active-text-wrap">
                    <text class="s-text-active">"{{sentence.text}}"</text>
                 </view>
                 
                 <!-- The Giant Microphone Button -->
                 <view class="giant-mic-container">
                    <!-- 🔒 课程锁定：只显示提示，不显示录音按钮 -->
                    <view wx:if="{{isLocked}}" class="locked-hint">
                      <text class="locked-icon">🏆</text>
                      <text class="locked-text">课程已完成评分，无法继续录音</text>
                    </view>

                    <!-- 录音控件：未锁定时显示 -->
                    <view wx:else class="giant-mic-container">
                      <view class="giant-mic-btn {{isRecording ? 'is-recording' : ''}} {{playingIndex === currentIndex ? 'is-playing' : ''}}"
                            bindtouchstart="onRecordStart" bindtouchend="onRecordStop" catch:touchmove="onRecordStop">
                        <view class="mic-inner">
                          <text class="mic-icon" wx:if="{{isRecording}}">🔴</text>
                          <text class="mic-icon playing-breathe" wx:elif="{{playingIndex === currentIndex}}">🔊</text>
                          <text class="mic-icon" wx:else>🎙️</text>
                        </view>
                      </view>
                      
                      <view class="mic-hint-badge">
                        <text wx:if="{{isRecording}}">RELEASE TO FINISH</text>
                        <text wx:elif="{{playingIndex === currentIndex}}">NOW PLAYING</text>
                        <text wx:else>TAP & HOLD TO RECORD</text>
                      </view>
                    </view>
                 </view>
              </view>

            </view>
          </view>
        </view>
      </view>
      
      <!-- 底部安全留白，确保能滚到底部 -->
      <view class="bottom-spacer"></view>
    </scroll-view>

    <!-- 底部 Change Adventure / Submit Action Area -->
    <view class="bottom-action-bar" wx:if="{{recordedCount > 0 && !isLocked}}">
      <view 
        class="submit-adventure-btn {{submitting ? 'submitting' : ''}}"
        bindtap="onSubmit"
      >
         <text class="btn-icon">{{allDone ? '✅' : '📤'}}</text>
         <text class="btn-text">{{allDone ? 'Submit Adventure' : 'Submit Early'}}</text>
      </view>
    </view>
  </block>

  <!-- Stars overlay -->
  <view 
    wx:for="{{flyingStars}}" 
    wx:key="id" 
    class="flying-star" 
    style="left: {{item.x}}px; top: {{item.y}}px; opacity: {{item.opacity}}; transform: scale({{item.scale}});"
  >
    ⭐
  </view>
</view>
