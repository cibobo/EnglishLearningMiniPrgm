<!-- pages/reading/reading.wxml -->
<view class="page">
  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spinner"></view>
    <text>加载中…</text>
  </view>

  <block wx:else>
    <!-- 句子和图片滚动区 -->
    <scroll-view
      class="content-area"
      scroll-y
      scroll-into-view="{{scrollToView}}"
      scroll-with-animation
      scroll-top="0"
      bindscroll="onScroll"
    >
      <!-- 课程封面 -->
      <view class="cover-wrap" id="cover">
        <image class="cover-img" src="{{lesson.imageUrl}}" mode="aspectFill" />
        <view class="cover-overlay">
          <text class="lesson-title-overlay">{{lesson.title}}</text>
          <text class="progress-text">录音打卡进度：{{recordedCount}} / {{sentences.length}}</text>
        </view>
      </view>

      <!-- 按组排列的打卡图片和对应的句子 -->
      <view class="groups-container">
        <view 
          wx:for="{{groups}}" 
          wx:for-item="group" 
          wx:for-index="gIndex" 
          wx:key="id" 
          id="{{group.id}}" 
          class="image-group"
        >
          <!-- 悬浮卡片图片 -->
          <view class="group-card" bindtap="onGroupTap" data-group-index="{{gIndex}}">
            <image class="group-image" src="{{group.imageUrl}}" mode="widthFix" />
            <view class="expansion-hint">
              <text wx:if="{{activeGroupIndex !== gIndex}}">点击展开句子 ▼</text>
              <text wx:else>点击收起 ▲</text>
            </view>
          </view>
          
          <!-- 手风琴展开的句子列表 -->
          <view class="sentences-list {{activeGroupIndex === gIndex ? 'expanded' : ''}}">
            <view
              wx:for="{{group.sentences}}"
              wx:for-item="sentence"
              wx:for-index="sIdx"
              wx:key="id"
              id="sentence-{{group.indices[sIdx]}}"
              class="sentence-row {{group.indices[sIdx] === currentIndex ? 'active' : ''}} {{recordings[group.indices[sIdx]] ? 'recorded' : ''}}"
              bindtap="onSentenceTap"
              data-index="{{group.indices[sIdx]}}"
            >
              <text class="sentence-num">{{group.indices[sIdx] + 1}}</text>
              <text class="sentence-text">{{sentence.text}}</text>
              <view class="sentence-status">
                <text wx:if="{{playingIndex === group.indices[sIdx]}}">🔊</text>
                <text wx:elif="{{recordings[group.indices[sIdx]]}}">✅</text>
                <text wx:elif="{{group.indices[sIdx] === currentIndex}}">👉</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      
      <!-- padding bottom spacer -->
      <view class="bottom-spacer"></view>
    </scroll-view>

    <!-- 底部悬浮操作区 -->
    <view class="floating-action-bar">
      <view class="btn-row">
        <!-- 结束并发送 -->
        <button
          wx:if="{{recordedCount > 0}}"
          class="btn-submit {{submitting ? 'submitting' : ''}}"
          bindtap="onSubmit"
          loading="{{submitting}}"
          disabled="{{submitting}}"
        >
          {{allDone ? '✅ 直接发送' : '📤 提前发送'}}
        </button>

        <!-- 按住跟读 (悬浮主体) -->
        <view
          class="btn-record {{isRecording ? 'recording' : ''}}"
          bindtouchstart="onRecordStart"
          bindtouchend="onRecordStop"
          catch:touchmove="onRecordStop"
        >
          <view wx:if="{{isRecording}}" class="record-pulse"></view>
          <text>{{isRecording ? '🎙 录音中…松开完成' : '● 按住开始跟读'}}</text>
        </view>
      </view>
    </view>
  </block>
</view>
