/* pages/reading/reading.wxss */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
}

/* =============================================
   Global Immersive Background
   ============================================= */
.global-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -2;
  filter: blur(10px) brightness(1.0);
  transform: scale(1.08);
  transition: src 0s; /* Images can't transition `src` but the image element fades naturally */
}

.global-bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  background: rgba(238, 253, 242, 0.30); /* Light tint - keep illustration recognizable */
}

/* =============================================
   Header (Top Glass Card)
   ============================================= */
.top-header-glass {
  position: relative;
  overflow: hidden;
  padding: 180rpx 40rpx 32rpx;
  border-bottom-left-radius: 48rpx;
  border-bottom-right-radius: 48rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.06);
  z-index: 50;
  flex-shrink: 0;
  border-bottom: 2rpx solid rgba(255,255,255,0.8);
}

.header-bg-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -2;
  filter: blur(4px);
  transform: scale(1.1);
}

.header-bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  background: rgba(255, 255, 255, 0.75); /* High opacity white to make text pop over the blurred image */
}

/* =============================================
   Navigation Back Button (Match Native Capsule)
   ============================================= */
.nav-back-pill {
  position: absolute;
  left: 32rpx;
  /* top, height, width dynamic in WXML */
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.15); /* Native translucent dark */
  border: 1px solid rgba(255, 255, 255, 0.25);
  box-shadow: none; /* Removed cartoon shadow */
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s ease;
  z-index: 100;
  box-sizing: border-box;
}
.nav-back-pill-hover {
  background: rgba(0, 0, 0, 0.3); /* Darken on press */
  transform: none; /* Removed bounce */
  box-shadow: none;
}
.nav-pill-icon {
  width: 36rpx;
  height: 36rpx;
  /* Hollow thick left chevron */
  background-image: url("data:image/svg+xml,%3Csvg width='24' height='24' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M14 18L8 12L14 6' stroke='white' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  background-size: contain;
  background-position: center;
  background-repeat: no-repeat;
  margin-right: 2rpx; /* Optical centering */
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.header-thumb {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid #c2e8ff; /* secondary container */
  background: #eefdf2;
}

.header-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #7e5700;
  max-width: 320rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header-progress {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #ffffff;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.progress-text {
  font-size: 28rpx;
  font-weight: 800;
  color: #006688;
}

.star-icon {
  font-size: 32rpx;
  line-height: 1;
}

.header-progress-track {
  width: 100%;
  height: 16rpx;
  background: rgba(0,0,0,0.05);
  border-radius: 999rpx;
  overflow: hidden;
}

.header-progress-fill {
  height: 100%;
  background: #ffba38;
  border-radius: 999rpx;
  transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

/* =============================================
   Header Themes
   ============================================= */
/* Theme Primary (Orange/Yellow) */
.top-header-glass.theme-primary .header-bg-overlay { background: rgba(255, 222, 172, 0.85); }
.top-header-glass.theme-primary .header-thumb { border-color: #ffd9df; }
.top-header-glass.theme-primary .header-title { color: #604100; }
.top-header-glass.theme-primary .progress-text { color: #604100; }
.top-header-glass.theme-primary .header-progress-fill { background: #ffba38; }

/* Theme Secondary (Sky Blue) */
.top-header-glass.theme-secondary .header-bg-overlay { background: rgba(194, 232, 255, 0.85); }
.top-header-glass.theme-secondary .header-thumb { border-color: #ffdeac; }
.top-header-glass.theme-secondary .header-title { color: #004d67; }
.top-header-glass.theme-secondary .progress-text { color: #004d67; }
.top-header-glass.theme-secondary .header-progress-fill { background: #75d1ff; }

/* Theme Tertiary (Soft Pink) */
.top-header-glass.theme-tertiary .header-bg-overlay { background: rgba(255, 217, 223, 0.85); }
.top-header-glass.theme-tertiary .header-thumb { border-color: #c2e8ff; }
.top-header-glass.theme-tertiary .header-title { color: #81233f; }
.top-header-glass.theme-tertiary .progress-text { color: #81233f; }
.top-header-glass.theme-tertiary .header-progress-fill { background: #ffb1c0; }

/* =============================================
   List Content & Groups
   ============================================= */
.content-scroll {
  flex: 1;
  height: 0;
  box-sizing: border-box;
}

.groups-container {
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.image-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* Group anchor - invisible zero-height marker for scroll detection */
.group-anchor {
  height: 0;
  overflow: hidden;
}

.sentences-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* =============================================
   Sentence Cards (Bouncy Standard)
   ============================================= */
.bouncy-sentence-card {
  border-radius: 32rpx;
  transition: all 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  overflow: hidden;
}

/* Locked (Not read yet, and not current) */
.card-locked {
  background: rgba(255,255,255,0.5);
  border: 4rpx dashed #c6c6c6;
  opacity: 0.8;
  padding: 32rpx;
}
.card-locked .s-text {
  color: #777777;
  font-weight: 600;
  font-style: italic;
  font-size: 32rpx;
}

/* Completed */
.card-completed {
  background: #e8f7ec; /* surface-container-low */
  border-bottom: 8rpx solid #d7e6dc;
  padding: 32rpx;
}
.card-completed .s-text {
  color: #121e18;
  font-weight: 700;
  font-size: 32rpx;
}

.sentence-text-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}
.status-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  line-height: normal;
}

/* =============================================
   Active Sentence & Giant Mic
   ============================================= */
.card-active {
  background: #ffdeac; /* primary-container */
  border: 8rpx solid #006688; /* secondary */
  border-radius: 40rpx;
  box-shadow: 0 16rpx 0px #004d67;
  transform: rotate(-1deg);
  margin: 16rpx 0;
  transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* When audio is playing: straighten the card */
.card-active.card-playing {
  transform: rotate(0deg);
  box-shadow: 0 16rpx 0px #004d67, 0 0 0 6rpx rgba(0, 180, 100, 0.25);
}

.active-content-layout {
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 48rpx;
}

.active-text-wrap {
  text-align: center;
}

.s-text-active {
  font-size: 44rpx;
  font-weight: 800;
  color: #604100;
  line-height: 1.4;
  display: block;
}

/* Microphone Area */
.giant-mic-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.mic-btn-wrapper {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-playback-btn {
  position: absolute;
  right: -60rpx;
  bottom: 0rpx;
  width: 80rpx;
  height: 80rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 77, 79, 0.25);
  z-index: 110;
  transition: all 0.2s;
  border: 4rpx solid #ff4d4f;
}

.user-playback-btn.playing {
  background: #ff4d4f;
  transform: scale(1.1);
  box-shadow: 0 8rpx 20rpx rgba(255, 77, 79, 0.4);
}

.user-playback-btn:active {
  transform: scale(0.9);
}

.icon-speaker {
  width: 44rpx;
  height: 44rpx;
  background-color: #ff4d4f;
  -webkit-mask: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z'/%3E%3C/svg%3E") no-repeat center;
  mask: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z'/%3E%3C/svg%3E") no-repeat center;
  -webkit-mask-size: contain;
  mask-size: contain;
}

.user-playback-btn.playing .icon-speaker {
  background-color: #ffffff;
  animation: mic-breathe 1.5s ease-in-out infinite;
}

.giant-mic-btn {
  width: 240rpx;
  height: 240rpx;
  background: #006688; /* secondary */
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 0px #004d67;
  transition: all 0.15s;
}

/* Inner Core */
.mic-inner {
  width: 180rpx;
  height: 180rpx;
  background: #c2e8ff; /* secondary-fixed */
  border-radius: 50%;
  border: 8rpx solid rgba(0, 77, 103, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s;
}

.mic-icon {
  font-size: 80rpx;
}

/* Recording State */
.giant-mic-btn.is-recording {
  background: #ffb1c0;
  box-shadow: 0 6rpx 0px #81233f;
  transform: translateY(10rpx);
}
.giant-mic-btn.is-recording .mic-inner {
  background: #ffd9df;
  border-color: rgba(129, 35, 63, 0.2);
  transform: scale(0.9);
}

/* Playing State (green) */
.giant-mic-btn.is-playing {
  background: #1a9e5c;
  box-shadow: 0 16rpx 0px #0d5e36;
}
.giant-mic-btn.is-playing .mic-inner {
  background: #b7f0d4;
  border-color: rgba(13, 94, 54, 0.2);
}

.recording-pulse {
  animation: giant-pulse 1s infinite alternate;
}
@keyframes giant-pulse {
  0% { transform: scale(1); opacity: 1; }
  100% { transform: scale(1.3); opacity: 0.8; }
}

/* Microphone Breathing Animation (For Playback) */
@keyframes mic-breathe {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.15); opacity: 0.8; }
  100% { transform: scale(1); opacity: 1; }
}

.playing-breathe {
  animation: mic-breathe 1.5s ease-in-out infinite;
  display: inline-block;
}

/* =============================================
   Locked State
   ============================================= */
@keyframes fade-in-up {
  0% { transform: translateY(20rpx); opacity: 0; }
  100% { transform: translateY(0); opacity: 1; }
}

.locked-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 60rpx;
  opacity: 0;
  animation: fade-in-up 0.5s ease 0.3s forwards;
}
.locked-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}
.locked-text {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.mic-hint-badge {
  background: rgba(96, 65, 0, 0.1);
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
}
.mic-hint-badge text {
  font-size: 24rpx;
  font-weight: 800;
  color: #604100;
  letter-spacing: 2rpx;
}

/* =============================================
   Giant Mic Hit Area
   完全透明的触摸拦截层，位置固定不变，用来接收所有触摸手势，
   防止录音时 DOM 重建导致的丢失 touchend 事件问题。
   ============================================= */
.giant-mic-hit-area {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 280rpx; /* 故意比可视按钮 240rpx 更大，增加触发区域 */
  height: 280rpx;
  z-index: 100;
  background: transparent;
}

/* =============================================
   Bottom Sticky Bar (Submit / Change Adventure)
   ============================================= */
.bottom-spacer {
  height: 220rpx; 
}

.bottom-action-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0 40rpx 80rpx; /* safe area padding */
  display: flex;
  justify-content: center;
  pointer-events: none; 
}

/* Because it's absolute, gradient obscuring isn't needed anymore unless desired. We just let the button float */

.submit-adventure-btn {
  pointer-events: auto;
  background: #a03b56; /* tertiary */
  color: #ffffff;
  padding: 32rpx 64rpx;
  border-radius: 999rpx;
  font-size: 36rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 12rpx 0px #81233f;
  transition: all 0.2s;
  animation: bouncy-in 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes bouncy-in {
  0% { transform: translateY(100rpx) scale(0.5); opacity: 0; }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}

.submit-adventure-btn:active {
  box-shadow: 0 6rpx 0px #81233f;
  transform: translateY(6rpx);
}

.submit-adventure-btn.submitting {
  opacity: 0.6;
  transform: scale(0.95);
}

/* Loading Wrapper */
.loading-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 40rpx;
  gap: 32rpx;
}
.skeleton-card {
  height: 240rpx;
  background: rgba(255,255,255,0.4);
  border-radius: 32rpx;
  animation: shimmer 1.5s infinite;
}
@keyframes shimmer {
  0% { opacity: 0.4; }
  50% { opacity: 0.8; }
  100% { opacity: 0.4; }
}

.flying-star {
  position: fixed;
  font-size: 48rpx;
  z-index: 9999;
  transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  pointer-events: none;
  text-shadow: 0 4rpx 12rpx rgba(250, 204, 21, 0.8);
}

