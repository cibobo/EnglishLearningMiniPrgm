/* pages/reading/reading.wxss */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
}

/* =============================================
   Global Immersive Background
   ============================================= */
.global-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -2;
  filter: blur(10px) brightness(1.0);
  transform: scale(1.08);
  transition: src 0s; /* Images can't transition `src` but the image element fades naturally */
}

.global-bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  background: rgba(238, 253, 242, 0.30); /* Light tint - keep illustration recognizable */
}

/* =============================================
   Header (Top Glass Card)
   ============================================= */
.top-header-glass {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20px);
  padding: 100rpx 40rpx 32rpx;
  border-bottom-left-radius: 48rpx;
  border-bottom-right-radius: 48rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.06);
  z-index: 50;
  flex-shrink: 0;
  border-bottom: 2rpx solid rgba(255,255,255,0.8);
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.header-thumb {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid #c2e8ff; /* secondary container */
  background: #eefdf2;
}

.header-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #7e5700;
  max-width: 320rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header-progress {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #ffffff;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.progress-text {
  font-size: 28rpx;
  font-weight: 800;
  color: #006688;
}

.star-icon {
  font-size: 32rpx;
  line-height: 1;
}

.header-progress-track {
  width: 100%;
  height: 16rpx;
  background: rgba(0,0,0,0.05);
  border-radius: 999rpx;
  overflow: hidden;
}

.header-progress-fill {
  height: 100%;
  background: #ffba38;
  border-radius: 999rpx;
  transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

/* =============================================
   List Content & Groups
   ============================================= */
.content-scroll {
  flex: 1;
  height: 0;
  box-sizing: border-box;
}

.groups-container {
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.image-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* Group anchor - invisible zero-height marker for scroll detection */
.group-anchor {
  height: 0;
  overflow: hidden;
}

.sentences-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* =============================================
   Sentence Cards (Bouncy Standard)
   ============================================= */
.bouncy-sentence-card {
  border-radius: 32rpx;
  transition: all 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  overflow: hidden;
}

/* Locked (Not read yet, and not current) */
.card-locked {
  background: rgba(255,255,255,0.5);
  border: 4rpx dashed #c6c6c6;
  opacity: 0.8;
  padding: 32rpx;
}
.card-locked .s-text {
  color: #777777;
  font-weight: 600;
  font-style: italic;
  font-size: 32rpx;
}

/* Completed */
.card-completed {
  background: #e8f7ec; /* surface-container-low */
  border-bottom: 8rpx solid #d7e6dc;
  padding: 32rpx;
}
.card-completed .s-text {
  color: #121e18;
  font-weight: 700;
  font-size: 32rpx;
}

.sentence-text-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}
.status-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  line-height: normal;
}

/* =============================================
   Active Sentence & Giant Mic
   ============================================= */
.card-active {
  background: #ffdeac; /* primary-container */
  border: 8rpx solid #006688; /* secondary */
  border-radius: 40rpx;
  box-shadow: 0 16rpx 0px #004d67;
  transform: rotate(-1deg);
  margin: 16rpx 0;
}

.active-content-layout {
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 48rpx;
}

.active-text-wrap {
  text-align: center;
}

.s-text-active {
  font-size: 44rpx;
  font-weight: 800;
  color: #604100;
  line-height: 1.4;
  display: block;
}

/* Microphone Area */
.giant-mic-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.giant-mic-btn {
  width: 240rpx;
  height: 240rpx;
  background: #006688; /* secondary */
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 0px #004d67;
  transition: all 0.15s;
}

/* Inner Core */
.mic-inner {
  width: 180rpx;
  height: 180rpx;
  background: #c2e8ff; /* secondary-fixed */
  border-radius: 50%;
  border: 8rpx solid rgba(0, 77, 103, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s;
}

.mic-icon {
  font-size: 80rpx;
}

/* Recording State */
.giant-mic-btn.is-recording {
  background: #ffb1c0;
  box-shadow: 0 6rpx 0px #81233f;
  transform: translateY(10rpx);
}
.giant-mic-btn.is-recording .mic-inner {
  background: #ffd9df;
  border-color: rgba(129, 35, 63, 0.2);
  transform: scale(0.9);
}

.recording-pulse {
  animation: giant-pulse 1s infinite alternate;
}
@keyframes giant-pulse {
  0% { transform: scale(1); opacity: 1; }
  100% { transform: scale(1.3); opacity: 0.8; }
}

.mic-hint-badge {
  background: rgba(96, 65, 0, 0.1);
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
}
.mic-hint-badge text {
  font-size: 24rpx;
  font-weight: 800;
  color: #604100;
  letter-spacing: 2rpx;
}

/* =============================================
   Bottom Sticky Bar (Submit / Change Adventure)
   ============================================= */
.bottom-spacer {
  height: 220rpx; 
}

.bottom-action-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0 40rpx 80rpx; /* safe area padding */
  display: flex;
  justify-content: center;
  pointer-events: none; 
}

/* Because it's absolute, gradient obscuring isn't needed anymore unless desired. We just let the button float */

.submit-adventure-btn {
  pointer-events: auto;
  background: #a03b56; /* tertiary */
  color: #ffffff;
  padding: 32rpx 64rpx;
  border-radius: 999rpx;
  font-size: 36rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 12rpx 0px #81233f;
  transition: all 0.2s;
  animation: bouncy-in 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes bouncy-in {
  0% { transform: translateY(100rpx) scale(0.5); opacity: 0; }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}

.submit-adventure-btn:active {
  box-shadow: 0 6rpx 0px #81233f;
  transform: translateY(6rpx);
}

.submit-adventure-btn.submitting {
  opacity: 0.6;
  transform: scale(0.95);
}

/* Loading Wrapper */
.loading-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 40rpx;
  gap: 32rpx;
}
.skeleton-card {
  height: 240rpx;
  background: rgba(255,255,255,0.4);
  border-radius: 32rpx;
  animation: shimmer 1.5s infinite;
}
@keyframes shimmer {
  0% { opacity: 0.4; }
  50% { opacity: 0.8; }
  100% { opacity: 0.4; }
}

.flying-star {
  position: fixed;
  font-size: 48rpx;
  z-index: 9999;
  transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  pointer-events: none;
  text-shadow: 0 4rpx 12rpx rgba(250, 204, 21, 0.8);
}
