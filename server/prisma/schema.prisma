// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Teacher {
  id           String    @id @default(uuid())
  username     String    @unique @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String    @db.VarChar(100)
  role         String    @default("teacher") @db.VarChar(20)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  classes Class[]
  lessons Lesson[]  // 教师拥有的课程库
  lessonGroups LessonGroup[] // 教师创建的课程分组

  @@map("teachers")
}

model Class {
  id          String    @id @default(uuid())
  teacherId   String    @map("teacher_id")
  name        String    @db.VarChar(100)
  description String?   @db.VarChar(500)
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  teacher      Teacher       @relation(fields: [teacherId], references: [id])
  students     Student[]
  classLessons ClassLesson[] // 通过关联表访问课程

  @@map("classes")
}

// 课程库（不绑定班级，属于教师）
model Lesson {
  id         String    @id @default(uuid())
  title          String    @db.VarChar(200)
  imageUrl       String    @map("image_url") @db.VarChar(500)
  masterAudioUrl        String?  @map("master_audio_url") @db.VarChar(500)
  requiresTeacherReview Boolean  @default(false) @map("requires_teacher_review")
  createdAt  DateTime  @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")

  teachers             Teacher[]
  classLessons         ClassLesson[]        // 通过关联表访问班级
  sentences            Sentence[]
  recordingSubmissions RecordingSubmission[]
  lessonGroupItems     LessonGroupItem[]    // 通过关联表访问分组
  lessonScores         LessonScore[]

  @@map("lessons")
}

// 班级-课程 多对多关联表
model ClassLesson {
  classId    String   @map("class_id")
  lessonId   String   @map("lesson_id")
  orderIndex Int      @default(0) @map("order_index")
  assignedAt DateTime @default(now()) @map("assigned_at")

  class  Class  @relation(fields: [classId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@id([classId, lessonId])
  @@map("class_lessons")
}

model Student {
  id          String    @id @default(uuid())
  openid      String?   @unique @db.VarChar(100)
  studentCode String    @unique @map("student_code") @db.VarChar(6)
  name        String    @db.VarChar(100)
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")
  lastLoginAt DateTime? @map("last_login_at")
  loginStreak Int       @default(0) @map("login_streak")

  classes              Class[]
  recordingSubmissions RecordingSubmission[]
  lessonScores         LessonScore[]

  @@map("students")
}

model Sentence {
  id         String  @id @default(uuid())
  lessonId   String  @map("lesson_id")
  text       String  @db.VarChar(500)
  audioUrl   String? @map("audio_url") @db.VarChar(500)
  startTime  Float?  @map("start_time")
  endTime    Float?  @map("end_time")
  imageUrl   String? @map("image_url") @db.VarChar(500) 
  orderIndex Int     @default(0) @map("order_index")

  lesson               Lesson                @relation(fields: [lessonId], references: [id])
  recordingSubmissions RecordingSubmission[]

  @@map("sentences")
}

model RecordingSubmission {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  lessonId    String   @map("lesson_id")
  sentenceId  String   @map("sentence_id")
  audioUrl    String   @map("audio_url") @db.VarChar(500)
  status      String   @default("pending") @db.VarChar(20)
  score       Int?
  submittedAt DateTime @default(now()) @map("submitted_at")

  student  Student   @relation(fields: [studentId], references: [id])
  lesson   Lesson    @relation(fields: [lessonId], references: [id])
  sentence Sentence  @relation(fields: [sentenceId], references: [id])

  @@unique([studentId, sentenceId])
  @@map("recording_submissions")
}

model LessonScore {
  id           String   @id @default(uuid())
  studentId    String   @map("student_id")
  lessonId     String   @map("lesson_id")
  totalScore   Int      @map("total_score")
  maxScore     Int      @map("max_score")
  scorePercent Int      @map("score_percent")
  trophyLevel  String   @map("trophy_level")
  calculatedAt DateTime @default(now()) @map("calculated_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id])
  lesson  Lesson  @relation(fields: [lessonId], references: [id])

  @@unique([studentId, lessonId])
  @@map("lesson_scores")
}

// 课程分组（类似文件夹分类系统，一个课程可存在于多个分组）
model LessonGroup {
  id        String   @id @default(uuid())
  teacherId String   @map("teacher_id")
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  lessons   LessonGroupItem[]

  @@map("lesson_groups")
}

model LessonGroupItem {
  groupId  String   @map("group_id")
  lessonId String   @map("lesson_id")
  addedAt  DateTime @default(now()) @map("added_at")

  group    LessonGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  lesson   Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@id([groupId, lessonId])
  @@map("lesson_group_items")
}
