// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Teacher {
  id           String    @id @default(uuid())
  username     String    @unique @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String    @db.VarChar(100)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  classes Class[]

  @@map("teachers")
}

model Class {
  id          String    @id @default(uuid())
  teacherId   String    @map("teacher_id")
  name        String    @db.VarChar(100)
  description String?   @db.VarChar(500)
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  teacher  Teacher   @relation(fields: [teacherId], references: [id])
  students Student[]
  lessons  Lesson[]

  @@map("classes")
}

model Student {
  id          String    @id @default(uuid())
  openid      String?   @unique @db.VarChar(100)
  studentCode String    @unique @map("student_code") @db.VarChar(6)
  name        String    @db.VarChar(100)
  classId     String?   @map("class_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  class                Class?                @relation(fields: [classId], references: [id])
  recordingSubmissions RecordingSubmission[]

  @@map("students")
}

model Lesson {
  id          String    @id @default(uuid())
  classId     String    @map("class_id")
  title       String    @db.VarChar(200)
  imageUrl    String    @map("image_url") @db.VarChar(500)
  orderIndex  Int       @default(0) @map("order_index")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  class                Class                @relation(fields: [classId], references: [id])
  sentences            Sentence[]
  recordingSubmissions RecordingSubmission[]

  @@map("lessons")
}

model Sentence {
  id         String  @id @default(uuid())
  lessonId   String  @map("lesson_id")
  text       String  @db.VarChar(500)
  audioUrl   String? @map("audio_url") @db.VarChar(500)
  orderIndex Int     @default(0) @map("order_index")

  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@map("sentences")
}

model RecordingSubmission {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  lessonId    String   @map("lesson_id")
  audioUrl    String   @map("audio_url") @db.VarChar(500)
  status      String   @default("pending") @db.VarChar(20)
  submittedAt DateTime @default(now()) @map("submitted_at")

  student Student @relation(fields: [studentId], references: [id])
  lesson  Lesson  @relation(fields: [lessonId], references: [id])

  @@map("recording_submissions")
}
