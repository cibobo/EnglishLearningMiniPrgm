// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Teacher {
  id           String    @id @default(uuid())
  username     String    @unique @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String    @db.VarChar(100)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  classes Class[]
  lessons Lesson[]  // 教师拥有的课程库

  @@map("teachers")
}

model Class {
  id          String    @id @default(uuid())
  teacherId   String    @map("teacher_id")
  name        String    @db.VarChar(100)
  description String?   @db.VarChar(500)
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  teacher      Teacher       @relation(fields: [teacherId], references: [id])
  students     Student[]
  classLessons ClassLesson[] // 通过关联表访问课程

  @@map("classes")
}

// 课程库（不绑定班级，属于教师）
model Lesson {
  id         String    @id @default(uuid())
  teacherId  String    @map("teacher_id")
  title          String    @db.VarChar(200)
  imageUrl       String    @map("image_url") @db.VarChar(500)
  masterAudioUrl String?   @map("master_audio_url") @db.VarChar(500)
  createdAt  DateTime  @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")

  teacher              Teacher              @relation(fields: [teacherId], references: [id])
  classLessons         ClassLesson[]        // 通过关联表访问班级
  sentences            Sentence[]
  recordingSubmissions RecordingSubmission[]

  @@map("lessons")
}

// 班级-课程 多对多关联表
model ClassLesson {
  classId    String   @map("class_id")
  lessonId   String   @map("lesson_id")
  orderIndex Int      @default(0) @map("order_index")
  assignedAt DateTime @default(now()) @map("assigned_at")

  class  Class  @relation(fields: [classId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@id([classId, lessonId])
  @@map("class_lessons")
}

model Student {
  id          String    @id @default(uuid())
  openid      String?   @unique @db.VarChar(100)
  studentCode String    @unique @map("student_code") @db.VarChar(6)
  name        String    @db.VarChar(100)
  classId     String?   @map("class_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  class                Class?                @relation(fields: [classId], references: [id])
  recordingSubmissions RecordingSubmission[]

  @@map("students")
}

model Sentence {
  id         String  @id @default(uuid())
  lessonId   String  @map("lesson_id")
  text       String  @db.VarChar(500)
  audioUrl   String? @map("audio_url") @db.VarChar(500)
  startTime  Float?  @map("start_time")
  endTime    Float?  @map("end_time")
  imageUrl   String? @map("image_url") @db.VarChar(500) 
  orderIndex Int     @default(0) @map("order_index")

  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@map("sentences")
}

model RecordingSubmission {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  lessonId    String   @map("lesson_id")
  audioUrl    String   @map("audio_url") @db.VarChar(500)
  status      String   @default("pending") @db.VarChar(20)
  submittedAt DateTime @default(now()) @map("submitted_at")

  student Student @relation(fields: [studentId], references: [id])
  lesson  Lesson  @relation(fields: [lessonId], references: [id])

  @@map("recording_submissions")
}
