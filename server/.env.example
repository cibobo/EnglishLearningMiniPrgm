# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库 (MySQL)
DATABASE_URL="mysql://user:password@localhost:3306/learning_app"

# JWT 密钥
JWT_ACCESS_SECRET=your_access_secret_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_production
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# 微信小程序
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_app_secret

# 腾讯云 COS
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=your-bucket-name-1234567890
COS_REGION=ap-guangzhou
COS_DOMAIN=https://your-cdn-domain.com

# CORS 允许来源 (教师端 Web 地址)
CORS_ORIGIN=http://localhost:5173
